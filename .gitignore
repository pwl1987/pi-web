# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.factory

# editor / agent tooling
.zcode/
# Local Pi runtime state
.atl/

# vendored upstream source（由 scripts/sync-vendor.mjs 依据 VENDOR.lock 重新生成；VENDOR.lock 与 patches/ 受版本管理）
/vendor/autoplan/
/vendor/comet/

# OpenSpec 运行时状态（由 comet-guard 生成，类似 .next/，不入库；.comet.yaml 仍受版本管理）
openspec/**/.comet/
